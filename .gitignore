# Ignore everything by default
*
 
# --- Then explicitly allow your custom folders ---
# Uncomment and rename these to match your actual folder names:
 
!themes/
!themes/procheads/
!themes/procheads/**
!plugins/
!plugins/procurement-heads-jobadder/
!plugins/procurement-heads-jobadder/**
!plugins/procheads/
!plugins/procheads/**
!.github/
!.github/workflows/
!.github/workflows/**
 
# Allow .gitignore files within those folders
!.gitignore
 
# Always ignore these even if inside tracked folders
uploads/
upgrade/
cache/
backup*/
*.log

plugins/procheads/logs
 